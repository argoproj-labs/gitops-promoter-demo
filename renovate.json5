{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'helpers:pinGitHubActionDigests',
  ],
  automerge: true,
  automergeType: 'pr',
  prHourlyLimit: 0,
  customManagers: [
    {
      customType: 'regex',
      description: 'GitOps Promoter Argo CD UI extension bundle URLs (github-releases, not gitops-promoter-helm)',
      managerFilePatterns: [
        '/(^|/)charts/argocd/values\\.yaml$/',
      ],
      datasourceTemplate: 'github-releases',
      packageNameTemplate: 'argoproj-labs/gitops-promoter',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
      matchStrings: [
        'https://github\\.com/argoproj-labs/gitops-promoter/releases/download/v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)/gitops-promoter-argocd-extension\\.tar\\.gz',
        'https://github\\.com/argoproj-labs/gitops-promoter/releases/download/v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)/gitops-promoter_',
        'gitops-promoter_(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)_checksums\\.txt',
      ],
    },
    {
      customType: 'regex',
      description: 'argocd-extension-installer init container (Quay)',
      managerFilePatterns: [
        '/(^|/)charts/argocd/values\\.yaml$/',
      ],
      datasourceTemplate: 'docker',
      packageNameTemplate: 'quay.io/argoprojlabs/argocd-extension-installer',
      matchStrings: [
        'image:\\s*quay\\.io/argoprojlabs/argocd-extension-installer:(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)(@(?<currentDigest>sha256:[a-f0-9]{64}))',
      ],
    },
  ],
  packageRules: [
    {
      description: 'Helm umbrella dependencies (Chart.yaml) across charts/',
      matchManagers: [
        'helmv3',
      ],
      automerge: true,
    },
    {
      description: 'Demo churn / small image pins in raw YAML',
      matchManagers: [
        'kubernetes',
      ],
      matchPackageNames: [
        'alpine/git',
        'alpine',
      ],
      automerge: true,
    },
  ],
}
